# PostgreSQL (required for storing form submissions)
# DATABASE_URL=postgresql://user:password@localhost:5432/prelaunch

# Public URL of the app (for email logo). Set in production so the green logo appears in emails.
# PUBLIC_APP_URL=https://your-prelaunch-domain.com

# SMTP (MailHog in local dev). Start with: docker-compose up -d
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@welpco.com

# MailHog web UI: http://localhost:8025

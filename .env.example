# PostgreSQL (required for storing form submissions)
# DATABASE_URL=postgresql://user:password@localhost:5432/prelaunch

# Public URL of the app (for email logo). Set in production so the green logo appears in emails.
# PUBLIC_APP_URL=https://your-prelaunch-domain.com

# Meta (Facebook) Pixel — numeric ID from Events Manager (NEXT_PUBLIC_ so the browser can load the tag).
# NEXT_PUBLIC_META_PIXEL_ID=123456789012345

# SMTP – Resend in production, MailHog in local dev (docker-compose up -d)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_FROM=noreply@welpco.com
SMTP_USER=resend
SMTP_PASS=re_YOUR_API_KEY

# MailHog (local dev): set SMTP_HOST=localhost, SMTP_PORT=1025, remove USER/PASS
# MailHog web UI: http://localhost:8025

# Admin dashboard – access at /admin?key=YOUR_KEY
ADMIN_API_KEY=change-me
